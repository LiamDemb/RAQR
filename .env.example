# === Required (API key) ===
OPENAI_API_KEY=sk-

# === Project & Paths ===
SEED=42
OUTPUT_DIR=data/processed
BENCHMARK_PATH=${OUTPUT_DIR}/benchmark.jsonl
DOCSTORE_PATH=${OUTPUT_DIR}/docstore.sqlite
RESULTS_DIR=results

# Dataset paths (at least one required for ingestion)
NQ_PATH=
2WIKI_PATH=

# Ingestion splits (01_ingest_data)
TRAIN_RATIO=0.8
DEV_RATIO=0.1
TEST_RATIO=0.1

# === Models (setup via make setup-models) ===
MODEL_NAME=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm
HF_HOME=${OUTPUT_DIR}/hf_cache
# Optional: for entity index embedding model (defaults to MODEL_NAME)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Generator & LLM ===
OPENAI_MODEL=gpt-4o-mini
GENERATOR_MAX_TOKENS=512

# === LLM IE (one-pass extraction; used by batch) ===
LLM_IE_MODEL=gpt-4o-mini
LLM_IE_TEMPERATURE=0.0
LLM_IE_MAX_TOKENS=4096

# === Query entity extraction (GraphRAG) ===
QUERY_ENTITY_MODEL=gpt-4o-mini

# === LLM Judge (evaluation) ===
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_JUDGE_TEMPERATURE=0.0

# === Dense Strategy ===
DENSE_TOP_K=10

# === GraphRAG Strategy ===
GRAPH_TOP_K=10
GRAPH_MAX_HOPS=2
GRAPH_BIDIRECTIONAL=true
GRAPH_ENTITY_VECTOR_TOP_K=3
GRAPH_ENTITY_VECTOR_THRESHOLD=0.5
GRAPH_START_ENTITY_WEIGHT=2.0
GRAPH_EXPANDED_ENTITY_WEIGHT=1.0
GRAPH_SYNERGY_GAMMA=0.5

# === Corpus Building (01_build_corpus) ===
MAX_PAGES=12
MAX_HOPS=2
MAX_LIST_PAGES=2
MAX_COUNTRY_PAGES=1
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=100

# === spaCy noun chunks (when ENTITY_USE_NOUN_CHUNKS=1) ===
ENTITY_USE_NOUN_CHUNKS=0

# === Optional prompt overrides (omit to use defaults) ===
# GENERATOR_BASE_PROMPT_FILE=
# LLM_JUDGE_PROMPT_FILE=
LLM_IE_PROMPT_FILE=prompts/llm_ie_extraction.txt
QUERY_ENTITY_PROMPT_FILE=prompts/query_entity_extraction.txt

# === Optional: HuggingFace token for gated models ===
# HF_TOKEN=hf_...
